---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-slate-50 py-12 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl font-extrabold text-slate-900 mb-4">
        College Resource Hub
      </h1>
      <p class="text-slate-600 mb-12 text-lg">
        Select your department to access notes, papers, and syllabus.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <a href="/branch/cse" class="group p-8 bg-white rounded-2xl shadow-sm border border-slate-200 hover:border-blue-500 hover:shadow-md transition-all">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">💻</div>
          <h2 class="text-xl font-bold text-slate-800">Computer Science</h2>
          <p class="text-blue-500 text-sm mt-4 font-medium opacity-0 group-hover:opacity-100 transition-opacity">View Semesters →</p>
        </a>

        <a href="/branch/mechanical" class="group p-8 bg-white rounded-2xl shadow-sm border border-slate-200 hover:border-orange-500 hover:shadow-md transition-all">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">⚙️</div>
          <h2 class="text-xl font-bold text-slate-800">Mechanical</h2>
          <p class="text-orange-500 text-sm mt-4 font-medium opacity-0 group-hover:opacity-100 transition-opacity">View Semesters →</p>
        </a>

        <a href="/branch/electrical" class="group p-8 bg-white rounded-2xl shadow-sm border border-slate-200 hover:border-yellow-500 hover:shadow-md transition-all">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">⚡</div>
          <h2 class="text-xl font-bold text-slate-800">Electrical</h2>
          <p class="text-yellow-600 text-sm mt-4 font-medium opacity-0 group-hover:opacity-100 transition-opacity">View Semesters →</p>
        </a>

      </div>
    </div>
  </main>
</Layout>