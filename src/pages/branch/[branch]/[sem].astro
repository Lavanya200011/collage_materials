---
// 1. Import the local JSON data
import resourcesData from '../../../data/resource.json';

// 2. Get the branch and semester from the URL
const { branch, sem } = Astro.params;

// 3. Clean the semester string (converts "sem-1" to "1")
const semNumber = sem?.replace('sem-', '');

// 4. Filter the JSON data to find matching files for THIS page
const filteredResources = resourcesData.filter(item => 
  item.branch.toLowerCase() === branch?.toLowerCase() && 
  item.semester.toString() === semNumber
);

// 5. Group them by Subject Name
const groupedResources = filteredResources.reduce((acc, obj) => {
  const key = obj.subject_name || "General Resources";
  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(obj);
  return acc;
}, {});

const subjects = Object.keys(groupedResources);
const branchName = branch?.toUpperCase();

import Layout from '../../../layouts/Layout.astro';
---

<Layout title={`${branchName} - Semester ${semNumber}`}>
  <main class="min-h-screen bg-slate-50 py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <a href={`/branch/${branch}`} class="text-blue-600 hover:text-blue-800 font-medium mb-8 inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Semesters
      </a>
      
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-slate-900 uppercase tracking-tight">
          {branchName} Engineering
        </h1>
        <p class="text-slate-500 text-lg">
          Resources for <span class="font-semibold text-blue-600 underline decoration-blue-200">Semester {semNumber}</span>
        </p>
      </div>

      <div class="space-y-10">
        {subjects.length > 0 ? (
          subjects.map((subject) => (
            <section class="animate-in fade-in slide-in-from-bottom-4 duration-500">
              <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-3">
                <span class="w-1.5 h-6 bg-blue-600 rounded-full"></span>
                {subject}
              </h2>
              
              <div class="grid gap-3">
                {groupedResources[subject].map((item) => (
                  <div class="p-4 bg-white border border-slate-200 rounded-xl flex justify-between items-center shadow-sm hover:shadow-md hover:border-blue-200 transition-all group">
                    <div class="flex items-center gap-3">
                      <div class="bg-blue-50 p-2 rounded-lg text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                      </div>
                      <div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-blue-500 mb-0.5 block">
                          {item.type}
                        </span>
                        <h3 class="text-slate-700 font-semibold">{item.title}</h3>
                      </div>
                    </div>
                    
                    <a 
                      href={item.file_url} 
                      target="_blank" 
                      class="px-4 py-2 text-sm font-bold text-blue-600 hover:bg-blue-50 rounded-lg transition-colors border border-transparent hover:border-blue-100"
                    >
                      View PDF
                    </a>
                  </div>
                ))}
              </div>
            </section>
          ))
        ) : (
          <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-slate-200">
            <div class="text-5xl mb-4">📂</div>
            <p class="text-slate-500 text-lg font-medium">No subjects added yet.</p>
            <p class="text-slate-400 text-sm">Check back later or help by uploading materials!</p>
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>