---
// 1. Import the JSON file you just created
import resourcesData from '../../../data/resources.json';

// 2. Get the branch and semester from the URL
const { branch, sem } = Astro.params;

// 3. Clean the semester string (converts "sem-1" to "1")
const semNumber = sem?.replace('sem-', '');

// 4. Filter the JSON data to find matching files
const filteredResources = resourcesData.filter(item => 
  item.branch.toLowerCase() === branch?.toLowerCase() && 
  item.semester.toString() === semNumber
);

// 5. Group them by Subject Name (to create headings on your page)
const groupedResources = filteredResources.reduce((acc, obj) => {
  const key = obj.subject_name || "General Resources";
  if (!acc[key]) acc[key] = [];
  acc[key].push(obj);
  return acc;
}, {});

const subjects = Object.keys(groupedResources);
---

<Layout title={`Semester ${semNumber} - ${branch}`}>
  <h1>{branch?.toUpperCase()} - Semester {semNumber}</h1>

  {subjects.length === 0 ? (
    <p>No resources found for this semester yet.</p>
  ) : (
    subjects.map((subject) => (
      <section class="subject-section">
        <h2>{subject}</h2>
        <div class="grid">
          {groupedResources[subject].map((item) => (
            <div class="card">
              <h3>{item.title}</h3>
              <span>Type: {item.type}</span>
              <a href={item.file_url} target="_blank" class="btn">
                View PDF
              </a>
            </div>
          ))}
        </div>
      </section>
    ))
  )}
</Layout>