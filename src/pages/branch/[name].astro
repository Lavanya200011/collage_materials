---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';

// This gets the branch name from the URL (e.g., "cse")
const { name } = Astro.params;
const semesters = [1, 2, 3, 4, 5, 6, 7, 8];

const branchNames = {
  cse: "Computer Science",
  mechanical: "Mechanical Engineering",
  electrical: "Electrical Engineering"
};

const displayName = branchNames[name] || name.toUpperCase();
---

<Layout>
  <main class="min-h-screen bg-slate-50 py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="text-blue-600 hover:underline mb-8 inline-block">← Back to Departments</a>
      
      <h1 class="text-3xl font-bold text-slate-900 mb-2">{displayName}</h1>
      <p class="text-slate-500 mb-10">Select your current semester to view materials.</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {semesters.map((sem) => (
          <a 
            href={`/branch/${name}/sem-${sem}`}
            class="p-6 bg-white border border-slate-200 rounded-xl text-center hover:bg-blue-500 hover:text-white transition-all shadow-sm font-semibold"
          >
            Semester {sem}
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>